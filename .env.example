# Cloudflare D1 — copie este arquivo para .env e preencha os valores
CF_ACCOUNT_ID=seu_account_id_aqui
CF_DATABASE_ID=seu_database_id_aqui
CF_API_TOKEN=seu_api_token_aqui

# Gemini API Key (opcional — para geração de propostas com IA)
GEMINI_API_KEY=sua_gemini_api_key_aqui

# Segredo para assinar tokens de sessão (use um valor aleatório longo)
SESSION_SECRET=troque_por_string_aleatoria_segura
